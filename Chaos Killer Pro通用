local gravityLoopActive = false
local gravityLoopConnection = nil

local function GetClasses(parent, className)
    local result = {}
    for _, child in ipairs(parent:GetDescendants()) do
        if child:IsA(className) then table.insert(result, child) end
    end
    return result
end

local function ForceStopGravityLoop()
    if gravityLoopConnection then gravityLoopConnection:Disconnect()
    gravityLoopConnection = nil end
    gravityLoopActive = false
    for _, part in ipairs(GetClasses(game.Workspace, "BasePart")) do
        if not part.Anchored then
            for _, force in ipairs(part:GetChildren()) do
                if force:IsA("BodyForce") and force.Name == "CustomGravity" then force:Destroy() end
            end
        end
    end
    Notify("重力", "已强制关闭")
end

GeneralTab:Input({
    Title = "零件重力",
    Desc = "正数向下,负数向上",
    Value = "",
    Callback = function(v) pendingGravity = v end
})

GeneralTab:Button({
    Title = "应用重力",
    Callback = function()
        local Gravity = tonumber(pendingGravity) or 0
        if gravityLoopConnection then gravityLoopConnection:Disconnect()
        gravityLoopConnection = nil end
        
        local playerChars = {}
        for _, p in ipairs(game.Players:GetPlayers()) do
            if p.Character then table.insert(playerChars, p.Character) end
        end
        
        local function SetGravity(part)
            for _, pc in ipairs(playerChars) do
                if part:IsDescendantOf(pc) then return end
            end
            if part:IsA("BasePart") and not part.Anchored then
                for _, f in ipairs(part:GetChildren()) do
                    if f:IsA("BodyForce") and f.Name == "CustomGravity" then f:Destroy() end
                end
                if Gravity ~= 0 then
                    local bf = Instance.new("BodyForce")
                    bf.Name = "CustomGravity"
                    bf.Force = Vector3.new(0, part:GetMass() * Gravity, 0)
                    bf.Parent = part
                end
            end
        end
        
        gravityLoopActive = true
        gravityLoopConnection = game:GetService("RunService").Heartbeat:Connect(function()
            if gravityLoopActive then
                for _, part in ipairs(GetClasses(game.Workspace, "BasePart")) do
                    SetGravity(part)
                end
            end
        end)
        workspace.DescendantAdded:Connect(SetGravity)
        if Gravity == 0 then
            Notify("重力", "已恢复默认")
        else
            Notify("重力", "已设为: " .. Gravity)
        end
    end
})

