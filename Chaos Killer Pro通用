RoleTab:Toggle({
    Title = "空中跳跃开关",
    Value = false,
    Callback = function(s)
        if airJumpHeartbeat then airJumpHeartbeat:Disconnect()
        airJumpHeartbeat = nil end
        if airJumpRequest then airJumpRequest:Disconnect()
        airJumpRequest = nil end
        airJumpEnabled = s
        if s then
            wasGrounded = true
            airJumpsUsed = 0
            airJumpHeartbeat = game:GetService("RunService").Heartbeat:Connect(function()
                if not airJumpEnabled then return end
                local g = isGrounded()
                if g and not wasGrounded then airJumpsUsed = 0 end
                wasGrounded = g
            end)
            airJumpRequest = game:GetService("UserInputService").JumpRequest:Connect(function()
                if not airJumpEnabled then return end
                local h = getHumanoid()
                local rp = game.Players.LocalPlayer.Character and game.Players.LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                if not h or not rp then return end
                local g = isGrounded()
                if g then
                    h:ChangeState(Enum.HumanoidStateType.Jumping)
                    airJumpsUsed = 0
                elseif airJumpsUsed < maxAirJumps then
                    local vel = rp.Velocity
                    rp.Velocity = Vector3.new(vel.X, h.JumpPower, vel.Z)
                    airJumpsUsed = airJumpsUsed + 1
                end
            end)
            Notify("空中跳跃", "已开启")
