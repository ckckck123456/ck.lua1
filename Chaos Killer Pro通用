local spinVelocityObj = nil
local isSpinning = false
local currentSpinSpeed = 0

local function startSpin()
    if isSpinning then return end
    local char = game.Players.LocalPlayer.Character
    if not char then
        Notify("错误", "角色未加载")
        return
    end
    local rootPart = char:FindFirstChild("HumanoidRootPart")
    if not rootPart then
        Notify("错误", "找不到RootPart")
        return
    end
    
    isSpinning = true
    spinVelocityObj = Instance.new("BodyAngularVelocity")
    spinVelocityObj.Name = "SpinVelocity"
    spinVelocityObj.MaxTorque = Vector3.new(0, math.huge, 0)
    spinVelocityObj.AngularVelocity = Vector3.new(0, currentSpinSpeed, 0)
    spinVelocityObj.Parent = rootPart
    Notify("旋转", "已开启，速度: " .. currentSpinSpeed)
end

local function stopSpin()
    if not isSpinning then return end
    isSpinning = false
    if spinVelocityObj then
        spinVelocityObj:Destroy()
        spinVelocityObj = nil
    end
    Notify("旋转", "已关闭")
end

local function updateSpinSpeed()
    if isSpinning and spinVelocityObj then
        spinVelocityObj.AngularVelocity = Vector3.new(0, currentSpinSpeed, 0)
    end
end

