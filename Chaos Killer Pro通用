local hitboxCollideLoop = nil
local hitboxCollideValue = 1
local selfHitboxCollideLoop = nil
local selfHitboxCollideValue = 1

local function applyHitboxCollide()
    if hitboxCollideLoop then hitboxCollideLoop:Disconnect() end
    hitboxCollideLoop = game:GetService("RunService").RenderStepped:Connect(function()
        for _, player in ipairs(game.Players:GetPlayers()) do
            if player ~= game.Players.LocalPlayer and player.Character then
                pcall(function()
                    for _, part in ipairs(player.Character:GetDescendants()) do
                        if part:IsA("BasePart") then
                            if hitboxCollideValue == 0 then
                                part.CanCollide = false; part.CanTouch = false
                            elseif hitboxCollideValue == 1 then
                                part.CanCollide = true; part.CanTouch = true
                            else
                                part.CanCollide = false; part.CanTouch = true
                            end
                        end
                    end
                end)
            end
        end
    end)
end

local function applySelfHitboxCollide()
    if selfHitboxCollideLoop then selfHitboxCollideLoop:Disconnect() end
    selfHitboxCollideLoop = game:GetService("RunService").RenderStepped:Connect(function()
        local player = game.Players.LocalPlayer
        if player and player.Character then
            pcall(function()
                for _, part in ipairs(player.Character:GetDescendants()) do
                    if part:IsA("BasePart") then
                        if selfHitboxCollideValue == 0 then
                            part.CanCollide = false; part.CanTouch = false
                        elseif selfHitboxCollideValue == 1 then
                            part.CanCollide = true; part.CanTouch = true
                        else
                            part.CanCollide = false; part.CanTouch = true
                        end
                    end
                end
            end)
        end
    end)
end

