local isExpanded = true
local expandedSize = UDim2.new(0, 220, 0, 200)
local collapsedSize = UDim2.new(0, 220, 0, 38)

local function toggleExpand()
    isExpanded = not isExpanded
    if isExpanded then
        ScrollFrame.Visible = true
        MainFrame:TweenSize(expandedSize, Enum.EasingDirection.Out, Enum.EasingStyle.Quad, 0.25, true)
        FoldButton.Text = "▼"
    else
        ScrollFrame.Visible = false
        MainFrame:TweenSize(collapsedSize, Enum.EasingDirection.Out, Enum.EasingStyle.Quad, 0.25, true)
        FoldButton.Text = "▲"
    end
end
FoldButton.MouseButton1Click:Connect(toggleExpand)
CloseButton.MouseButton1Click:Connect(function() ScreenGui:Destroy() end)

local function createButton(text, callback)
    local button = Instance.new("TextButton")
    button.Size = UDim2.new(0, 200, 0, 44)
    button.BackgroundColor3 = Color3.fromRGB(25, 25, 30)
    button.BackgroundTransparency = 0.1
    button.BorderSizePixel = 0
    button.Text = text
    button.TextColor3 = Color3.fromRGB(255, 255, 255)
    button.TextSize = 14
    button.Font = Enum.Font.GothamBold
    
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 10)
    corner.Parent = button
    
    button.MouseEnter:Connect(function()
        button.BackgroundColor3 = Color3.fromRGB(45, 45, 55)
    end)
    button.MouseLeave:Connect(function()
        button.BackgroundColor3 = Color3.fromRGB(25, 25, 30)
    end)
    
    button.Parent = ScrollFrame
    button.MouseButton1Click:Connect(callback)
    return button
end

